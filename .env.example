# Ecommerce Microservices - Environment Configuration Example
# Copy this file to .env and fill in your actual values
# This file should NOT be committed to version control with real secrets

# ============================================
# COMMON CONFIGURATION
# ============================================
SPRING_PROFILES_ACTIVE=dev
APP_NAME=ecommerce-microservices
ENVIRONMENT=development

# ============================================
# EUREKA SERVICE DISCOVERY
# ============================================
EUREKA_SERVER_URL=http://localhost:8761
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://discovery-service:8761/eureka/
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true

# ============================================
# DATABASE CONFIGURATION (MySQL)
# ============================================
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ecommerce
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root123
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQL8Dialect
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# ============================================
# DATABASE CONFIGURATION (PostgreSQL - Optional)
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ============================================
# MONGODB CONFIGURATION
# ============================================
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/ecommerce
SPRING_DATA_MONGODB_DATABASE=ecommerce
SPRING_DATA_MONGODB_USERNAME=mongouser
SPRING_DATA_MONGODB_PASSWORD=mongopass

# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ecommerce-group
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_TOPIC_PARTITION=3
KAFKA_TOPIC_REPLICATION_FACTOR=1

# ============================================
# ELASTICSEARCH CONFIGURATION
# ============================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_PROTOCOL=http
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elastic123

# ============================================
# JWT & SECURITY CONFIGURATION
# ============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-must-be-long-enough
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://localhost:8081/.well-known/jwks.json

# ============================================
# EMAIL/SMTP CONFIGURATION (Notification Service)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@ecommerce.com
MAIL_FROM_NAME=Ecommerce Platform
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_SMTP_CONNECTIONTIMEOUT=5000
SPRING_MAIL_SMTP_TIMEOUT=5000
SPRING_MAIL_SMTP_WRITETIMEOUT=5000

# ============================================
# API GATEWAY CONFIGURATION
# ============================================
API_GATEWAY_PORT=8888
GATEWAY_TIMEOUT=5000
GATEWAY_CONNECT_TIMEOUT=3000

# ============================================
# SERVICE PORTS
# ============================================
AUTH_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8080
ORDER_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083
PAYMENT_SERVICE_PORT=8084
INVENTORY_SERVICE_PORT=8085
RATING_SERVICE_PORT=8086
SEARCH_SERVICE_PORT=8087
SHIPPING_SERVICE_PORT=8088
TAX_SERVICE_PORT=8089
FAVOURITE_SERVICE_PORT=8090
MEDIA_SERVICE_PORT=8091
PROMOTION_SERVICE_PORT=8092
DISCOVERY_SERVICE_PORT=8761

# ============================================
# SERVICE URLS (For Internal Communication)
# ============================================
SERVICE_AUTH_URL=http://auth-service:8081
SERVICE_PRODUCT_URL=http://product-service:8080
SERVICE_ORDER_URL=http://order-service:8082
SERVICE_PAYMENT_URL=http://payment-service:8084
SERVICE_INVENTORY_URL=http://inventory-service:8085
SERVICE_NOTIFICATION_URL=http://notification-service:8083
SERVICE_RATING_URL=http://rating-service:8086
SERVICE_SEARCH_URL=http://search-service:8087
SERVICE_SHIPPING_URL=http://shipping-service:8088
SERVICE_TAX_URL=http://tax-service:8089
SERVICE_MEDIA_URL=http://media-service:8091

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ECOMMERCE=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=DEBUG
LOGGING_PATTERN_CONSOLE=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
LOGGING_FILE=/var/log/ecommerce/app.log

# ============================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================
STRIPE_API_KEY=sk_test_your_stripe_api_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================================
# FILE UPLOAD CONFIGURATION (Media Service)
# ============================================
FILE_UPLOAD_DIR=/tmp/ecommerce-uploads
FILE_UPLOAD_MAX_SIZE=10485760
FILE_UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx
FILE_UPLOAD_TEMP_DIR=/tmp/ecommerce-temp

# ============================================
# CACHE CONFIGURATION (Redis - Optional)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
SPRING_CACHE_TYPE=redis
SPRING_REDIS_TIMEOUT=2000

# ============================================
# AWS S3 CONFIGURATION (For File Storage - Optional)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=ecommerce-uploads
AWS_S3_REGION=us-east-1

# ============================================
# ACTUATOR & MONITORING
# ============================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_METRICS_ENABLE_ALL=true

# ============================================
# DOCKER CONFIGURATION
# ============================================
DOCKER_REGISTRY=localhost:5000
DOCKER_IMAGE_PREFIX=ecommerce
DOCKER_NETWORK=ecommerce-network

# ============================================
# DATABASE MIGRATION (Liquibase)
# ============================================
SPRING_LIQUIBASE_ENABLED=true
SPRING_LIQUIBASE_CHANGE_LOG=classpath:db/changelog/db.changelog-master.yaml

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_TIMEZONE=UTC
APP_LOCALE=en_US
APP_VERSION=1.0.0
APP_BUILD_DATE=2025-02-20

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_MAX_AGE=3600

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=5000

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_PAYMENT_PROCESSING_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS_ENABLED=true
FEATURE_SMS_NOTIFICATIONS_ENABLED=false
FEATURE_TWO_FACTOR_AUTH_ENABLED=false
FEATURE_RECOMMENDATION_ENGINE_ENABLED=true

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
DEPLOYMENT_ENVIRONMENT=development
DEPLOYMENT_REGION=local
DEPLOYMENT_VERSION=1.0.0
DEPLOYMENT_REPLICAS=1

# ============================================
# ACTUATOR HEALTH CHECK
# ============================================
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_ENABLED=true

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real secrets to version control
# 2. Use .env file in local development only
# 3. For production, use secure secret management (AWS Secrets Manager, HashiCorp Vault, etc.)
# 4. Change all default passwords and secrets
# 5. Update service URLs according to your deployment
# 6. For Docker Compose, use service names (e.g., http://mysql:3306) instead of localhost
# 7. Keep this file protected with proper file permissions (chmod 600 .env)
